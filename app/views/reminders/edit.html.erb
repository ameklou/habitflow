<% content_for :title, "Edit reminder" %>

<section class="mx-auto max-w-2xl py-10">
  <h1 class="text-3xl font-bold tracking-tight text-slate-950">Edit reminder</h1>
  <p class="mt-2 text-sm text-slate-600">Update this reminder's timing or delivery status.</p>

  <div class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <%= render "form", reminder: @reminder %>
  </div>
</section>
