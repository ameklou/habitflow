<%= form_with(model: reminder, class: "space-y-6") do |form| %>
  <% if reminder.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <h2 class="font-semibold"><%= pluralize(reminder.errors.count, "error") %> prevented this reminder from being saved.</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% reminder.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @habits.any? %>
    <div>
      <%= form.label :habit_id, "Habit", class: "block text-sm font-medium text-slate-800" %>
      <%= form.collection_select :habit_id, @habits, :id, :name, {}, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :reminder_time, class: "block text-sm font-medium text-slate-800" %>
        <%= form.time_field :reminder_time, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
      </div>

      <div>
        <%= form.label :channel, class: "block text-sm font-medium text-slate-800" %>
        <%= form.select :channel, Reminder.channels.keys.map { |channel| [ channel.humanize, channel ] }, {}, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
      </div>
    </div>

    <fieldset>
      <legend class="text-sm font-medium text-slate-800">Days</legend>
      <p class="mt-1 text-xs text-slate-500">Leave all unchecked to send every day.</p>
      <%= hidden_field_tag "reminder[days_of_week][]", "" %>
      <div class="mt-3 grid gap-2 sm:grid-cols-2">
        <% Habit::DAYS_OF_WEEK.each do |label, value| %>
          <label class="flex items-center gap-2 rounded-md border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700">
            <%= check_box_tag "reminder[days_of_week][]", value, reminder.days_of_week.include?(value), id: "reminder_days_of_week_#{value}", class: "h-4 w-4 rounded border-slate-300 text-emerald-700 focus:ring-emerald-600" %>
            <%= label %>
          </label>
        <% end %>
      </div>
    </fieldset>

    <div class="flex items-center gap-2">
      <%= form.check_box :enabled, class: "h-4 w-4 rounded border-slate-300 text-emerald-700 focus:ring-emerald-600" %>
      <%= form.label :enabled, class: "text-sm text-slate-700" %>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= form.submit class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
      <%= link_to "Cancel", reminders_path, class: "rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  <% else %>
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center">
      <h2 class="text-lg font-semibold text-slate-950">Create a habit first</h2>
      <p class="mt-2 text-sm text-slate-600">Reminders are attached to active habits.</p>
      <%= link_to "New habit", new_habit_path, class: "mt-5 inline-flex rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    </div>
  <% end %>
<% end %>
