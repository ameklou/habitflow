<% content_for :title, "Reminders" %>

<section class="py-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-950">Reminders</h1>
      <p class="mt-2 text-sm text-slate-600">Schedule email reminders for habits you want to complete.</p>
    </div>

    <%= link_to "New reminder", new_reminder_path, class: "inline-flex items-center justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
  </div>

  <% if @reminders.any? %>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <% @reminders.each do |reminder| %>
        <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="font-semibold text-slate-950"><%= link_to reminder.habit.name, reminder, class: "hover:text-emerald-700" %></h2>
              <p class="mt-2 text-sm text-slate-600"><%= reminder.reminder_time.strftime("%H:%M") %> by <%= reminder.channel.humanize.downcase %></p>
            </div>
            <span class="rounded-full px-3 py-1 text-xs font-medium <%= reminder.enabled? ? "bg-emerald-100 text-emerald-800" : "bg-slate-100 text-slate-600" %>">
              <%= reminder.enabled? ? "Enabled" : "Disabled" %>
            </span>
          </div>

          <div class="mt-5 flex flex-wrap gap-2">
            <%= link_to "Edit", edit_reminder_path(reminder), class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
            <%= button_to "Delete", reminder_path(reminder), method: :delete, data: { turbo_confirm: "Delete this reminder?" }, class: "rounded-md border border-red-300 px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="mt-8 rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center">
      <h2 class="text-lg font-semibold text-slate-950">No reminders yet</h2>
      <p class="mt-2 text-sm text-slate-600">Create a reminder after you have at least one active habit.</p>
      <%= link_to "Create reminder", new_reminder_path, class: "mt-5 inline-flex rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    </div>
  <% end %>
</section>
