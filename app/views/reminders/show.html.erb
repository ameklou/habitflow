<% content_for :title, "Reminder" %>

<section class="mx-auto max-w-2xl py-10">
  <p class="text-sm font-medium text-slate-500">Reminder</p>
  <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-950"><%= @reminder.habit.name %></h1>

  <dl class="mt-8 grid gap-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm sm:grid-cols-2">
    <div>
      <dt class="text-sm text-slate-500">Time</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @reminder.reminder_time.strftime("%H:%M") %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">Channel</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @reminder.channel.humanize %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">Status</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @reminder.enabled? ? "Enabled" : "Disabled" %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">Days</dt>
      <dd class="mt-1 font-semibold text-slate-950">
        <% if @reminder.days_of_week.any? %>
          <%= @reminder.days_of_week.map { |day| Habit::DAYS_OF_WEEK.key(day) }.join(", ") %>
        <% else %>
          Every day
        <% end %>
      </dd>
    </div>
  </dl>

  <div class="mt-8 flex flex-wrap gap-3">
    <%= link_to "Back to reminders", reminders_path, class: "rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    <%= link_to "Edit", edit_reminder_path(@reminder), class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    <%= button_to "Delete", reminder_path(@reminder), method: :delete, data: { turbo_confirm: "Delete this reminder?" }, class: "rounded-md border border-red-300 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
  </div>
</section>
