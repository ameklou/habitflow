<% flash.each do |type, message| %>
  <% next if message.blank? %>

  <% styles = type.to_sym == :alert ? "border-red-200 bg-red-50 text-red-800" : "border-emerald-200 bg-emerald-50 text-emerald-800" %>
  <div class="rounded-md border px-4 py-3 text-sm font-medium <%= styles %>" role="status">
    <%= message %>
  </div>
<% end %>
