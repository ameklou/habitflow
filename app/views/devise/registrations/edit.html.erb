<% content_for :title, "Edit profile" %>

<section class="mx-auto w-full max-w-2xl py-12">
  <h1 class="text-3xl font-bold tracking-tight text-slate-950">Edit profile</h1>
  <p class="mt-2 text-sm text-slate-600">Update your account details and password.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "mt-8 space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-800" %>
      <%= f.text_field :name, autocomplete: "name", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-800" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div>
      <%= f.label :timezone, class: "block text-sm font-medium text-slate-800" %>
      <%= f.time_zone_select :timezone, nil, {}, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
        Currently waiting confirmation for: <%= resource.unconfirmed_email %>
      </div>
    <% end %>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-slate-800" %>
      <p class="mt-1 text-xs text-slate-500">Leave blank if you do not want to change it.</p>
      <%= f.password_field :password, autocomplete: "new-password", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
      <% if @minimum_password_length %>
        <p class="mt-1 text-xs text-slate-500"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-800" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div>
      <%= f.label :current_password, class: "block text-sm font-medium text-slate-800" %>
      <p class="mt-1 text-xs text-slate-500">Required to confirm your changes.</p>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <%= f.submit "Update profile", class: "rounded-md bg-emerald-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-800" %>
  <% end %>

  <div class="mt-10 border-t border-slate-200 pt-6">
    <h2 class="text-base font-semibold text-slate-950">Cancel account</h2>
    <%= button_to "Cancel my account", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "mt-3 rounded-md border border-red-300 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
  </div>

  <%= link_to "Back", :back, class: "mt-8 inline-block text-sm font-medium text-slate-700 hover:text-slate-950" %>
</section>
