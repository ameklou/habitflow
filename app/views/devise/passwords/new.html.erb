<% content_for :title, "Reset password" %>

<section class="mx-auto w-full max-w-md py-12">
  <h1 class="text-3xl font-bold tracking-tight text-slate-950">Reset password</h1>
  <p class="mt-2 text-sm text-slate-600">Enter your email and we will send reset instructions.</p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-8 space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-800" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <%= f.submit "Send reset instructions", class: "w-full rounded-md bg-emerald-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-800" %>
  <% end %>

  <div class="mt-6 text-sm text-slate-600">
    <%= render "devise/shared/links" %>
  </div>
</section>
