<% content_for :title, "Log in" %>

<section class="mx-auto w-full max-w-md py-12">
  <h1 class="text-3xl font-bold tracking-tight text-slate-950">Log in</h1>
  <p class="mt-2 text-sm text-slate-600">Return to your habits and daily progress.</p>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-800" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-slate-800" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-emerald-700 focus:ring-emerald-600" %>
        <%= f.label :remember_me, class: "text-sm text-slate-700" %>
      </div>
    <% end %>

    <%= f.submit "Log in", class: "w-full rounded-md bg-emerald-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-800" %>
  <% end %>

  <div class="mt-6 text-sm text-slate-600">
    <%= render "devise/shared/links" %>
  </div>
</section>
