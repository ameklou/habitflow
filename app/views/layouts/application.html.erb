<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "HabitFlow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="HabitFlow">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Primary">
        <%= link_to "HabitFlow", root_path, class: "text-lg font-bold tracking-tight text-slate-950" %>

        <div class="flex items-center gap-3">
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= link_to "Habits", habits_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= link_to "Categories", categories_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= link_to "Stats", stats_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= link_to "Reminders", reminders_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= link_to "Achievements", achievements_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= link_to "Profile", edit_user_registration_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
          <% else %>
            <%= link_to "Log in", new_user_session_path, class: "text-sm font-medium text-slate-700 hover:text-slate-950" %>
            <%= link_to "Sign up", new_user_registration_path, class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
          <% end %>
        </div>
      </nav>
    </header>

    <div class="mx-auto mt-6 w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <%= render "shared/flash" %>
    </div>

    <main class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
