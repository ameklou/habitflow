<% content_for :title, "HabitFlow" %>

<section class="mx-auto grid w-full max-w-5xl gap-10 py-12 md:grid-cols-[1.1fr_0.9fr] md:items-center md:py-20">
  <div>
    <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">HabitFlow</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 md:text-5xl">Build habits one clear day at a time.</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">
      Track daily progress, keep streaks visible, and focus on the habits that matter today.
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <% if user_signed_in? %>
        <%= link_to "Open dashboard", dashboard_path, class: "rounded-md bg-emerald-700 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
        <%= link_to "Edit profile", edit_user_registration_path, class: "rounded-md border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50" %>
      <% else %>
        <%= link_to "Create account", new_user_registration_path, class: "rounded-md bg-emerald-700 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-emerald-800" %>
        <%= link_to "Log in", new_user_session_path, class: "rounded-md border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50" %>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-200 pb-4">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Today</h2>
        <p class="text-sm text-slate-500">Dashboard preview</p>
      </div>
      <span class="rounded-full bg-emerald-100 px-3 py-1 text-sm font-medium text-emerald-800">0 of 0</span>
    </div>

    <div class="mt-5 space-y-3">
      <div class="rounded-md border border-slate-200 p-4">
        <p class="font-medium text-slate-900">Create your first habit</p>
        <p class="mt-1 text-sm text-slate-500">Habit tracking starts after authentication and habit CRUD are added.</p>
      </div>
      <div class="rounded-md border border-dashed border-slate-300 p-4 text-sm text-slate-500">
        Streaks, weekly summaries, and completion actions will appear here in the next phases.
      </div>
    </div>
  </div>
</section>
