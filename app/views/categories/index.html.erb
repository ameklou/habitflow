<% content_for :title, "Categories" %>

<section class="py-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-950">Categories</h1>
      <p class="mt-2 text-sm text-slate-600">Group habits into areas like health, learning, and work.</p>
    </div>

    <%= link_to "New category", new_category_path, class: "inline-flex items-center justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
  </div>

  <% if @categories.any? %>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <% @categories.each do |category| %>
        <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="flex items-center gap-2">
                <% if category.color.present? %>
                  <span class="h-3 w-3 rounded-full" style="background-color: <%= category.color %>"></span>
                <% end %>
                <h2 class="font-semibold text-slate-950"><%= link_to category.name, category, class: "hover:text-emerald-700" %></h2>
              </div>
              <p class="mt-2 text-sm text-slate-600"><%= pluralize(category.habits.size, "habit") %></p>
            </div>

            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">Position <%= category.position %></span>
          </div>

          <div class="mt-5 flex flex-wrap gap-2">
            <%= link_to "Edit", edit_category_path(category), class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
            <%= button_to "Delete", category_path(category), method: :delete, data: { turbo_confirm: "Delete this category? Habits will become uncategorized." }, class: "rounded-md border border-red-300 px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="mt-8 rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center">
      <h2 class="text-lg font-semibold text-slate-950">No categories yet</h2>
      <p class="mt-2 text-sm text-slate-600">Create a category to organize your habits.</p>
      <%= link_to "Create category", new_category_path, class: "mt-5 inline-flex rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    </div>
  <% end %>
</section>
