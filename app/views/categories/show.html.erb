<% content_for :title, @category.name %>

<section class="mx-auto max-w-4xl py-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-medium text-slate-500">Category</p>
      <div class="mt-2 flex items-center gap-3">
        <% if @category.color.present? %>
          <span class="h-4 w-4 rounded-full" style="background-color: <%= @category.color %>"></span>
        <% end %>
        <h1 class="text-3xl font-bold tracking-tight text-slate-950"><%= @category.name %></h1>
      </div>
      <p class="mt-3 text-sm text-slate-600">Position <%= @category.position %></p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Back to categories", categories_path, class: "rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      <%= link_to "Edit", edit_category_path(@category), class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
      <%= button_to "Delete", category_path(@category), method: :delete, data: { turbo_confirm: "Delete this category? Habits will become uncategorized." }, class: "rounded-md border border-red-300 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
    </div>
  </div>

  <div class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-lg font-semibold text-slate-950">Habits</h2>
      <%= link_to "New habit", new_habit_path, class: "text-sm font-semibold text-emerald-700 hover:text-emerald-800" %>
    </div>

    <% if @habits.any? %>
      <ul class="mt-5 divide-y divide-slate-200">
        <% @habits.each do |habit| %>
          <li class="flex items-center justify-between gap-4 py-3">
            <div>
              <%= link_to habit.name, habit, class: "font-medium text-slate-950 hover:text-emerald-700" %>
              <p class="mt-1 text-sm text-slate-500"><%= habit.frequency.humanize %></p>
            </div>
            <% if habit.archived? %>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">Archived</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mt-5 text-sm text-slate-600">No habits are assigned to this category yet.</p>
    <% end %>
  </div>
</section>
