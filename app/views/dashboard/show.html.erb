<% content_for :title, "Dashboard" %>

<section class="py-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-950">Dashboard</h1>
      <p class="mt-2 text-sm text-slate-600"><%= Time.zone.today.strftime("%B %-d, %Y") %></p>
    </div>

    <%= link_to "New habit", new_habit_path, class: "inline-flex items-center justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
  </div>

  <%= render "habits/completion_summary", habits: @todays_habits %>

  <div class="mt-6 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-sm text-slate-500">Current streak</p>
    <p class="mt-1 text-3xl font-bold text-slate-950"><%= pluralize(@summary.current_streak, "day") %></p>
  </div>

  <div class="mt-8">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-xl font-semibold text-slate-950">Today's habits</h2>
      <%= link_to "Manage habits", habits_path, class: "text-sm font-semibold text-emerald-700 hover:text-emerald-800" %>
    </div>

    <% if @todays_habits.any? %>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <%= render @todays_habits %>
      </div>
    <% else %>
      <div class="mt-5 rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center">
        <h3 class="text-lg font-semibold text-slate-950">No habits due today</h3>
        <p class="mt-2 text-sm text-slate-600">Create a habit or adjust custom days to make it appear here.</p>
      </div>
    <% end %>
  </div>

  <div class="mt-10">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-xl font-semibold text-slate-950">Weekly summary</h2>
      <%= link_to "View stats", stats_path, class: "text-sm font-semibold text-emerald-700 hover:text-emerald-800" %>
    </div>

    <div class="mt-5 grid gap-3 sm:grid-cols-7">
      <% @weekly_summary.each do |day| %>
        <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
          <p class="text-sm font-medium text-slate-500"><%= day.date.strftime("%a") %></p>
          <p class="mt-2 text-2xl font-bold text-slate-950"><%= day.completed %>/<%= day.total %></p>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-emerald-600" style="width: <%= day.completion_rate %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
