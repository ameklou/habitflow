<% content_for :title, "Achievements" %>

<section class="py-10">
  <div>
    <h1 class="text-3xl font-bold tracking-tight text-slate-950">Achievements</h1>
    <p class="mt-2 text-sm text-slate-600">Track milestones unlocked through consistent habit progress.</p>
  </div>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    <% @achievements.each do |achievement| %>
      <% unlock = @unlocks_by_achievement_id[achievement.id] %>
      <article class="rounded-lg border bg-white p-5 shadow-sm <%= unlock ? "border-emerald-200" : "border-slate-200 opacity-75" %>">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase text-slate-500"><%= achievement.condition_type.humanize %></p>
            <h2 class="mt-1 text-lg font-semibold text-slate-950"><%= achievement.name %></h2>
            <p class="mt-2 text-sm text-slate-600"><%= achievement.description %></p>
          </div>

          <span class="rounded-full px-3 py-1 text-xs font-medium <%= unlock ? "bg-emerald-100 text-emerald-800" : "bg-slate-100 text-slate-600" %>">
            <%= unlock ? "Unlocked" : "Locked" %>
          </span>
        </div>

        <div class="mt-5 text-sm text-slate-600">
          Goal: <span class="font-semibold text-slate-950"><%= achievement.condition_value %></span>
          <% if unlock %>
            <span class="ml-3 text-emerald-700">Unlocked <%= time_ago_in_words(unlock.unlocked_at) %> ago</span>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>
