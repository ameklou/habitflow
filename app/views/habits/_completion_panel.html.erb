<% today = local_assigns.fetch(:date, Time.zone.today) %>
<% completion = habit.completion_on(today) %>

<div class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-lg font-semibold text-slate-950">Today</h2>
      <p class="text-sm text-slate-600"><%= today.to_fs(:long) %></p>
    </div>
    <% if completion.present? %>
      <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800">Completed</span>
    <% else %>
      <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800">Remaining</span>
    <% end %>
  </div>

  <% if completion.present? %>
    <% if completion.note.present? %>
      <p class="mt-4 rounded-md bg-emerald-50 px-3 py-2 text-sm text-emerald-800">Note: <%= completion.note %></p>
    <% end %>
    <%= button_to "Undo completion", habit_completion_path(habit), method: :delete, class: "mt-5 rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  <% elsif !habit.archived? %>
    <%= form_with(url: habit_completion_path(habit), scope: :habit_completion, class: "mt-5 space-y-3") do |form| %>
      <%= form.label :note, "Completion note", class: "block text-sm font-medium text-slate-700" %>
      <%= form.text_field :note, placeholder: "Optional note", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
      <%= form.submit "Complete today", class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    <% end %>
  <% end %>
</div>
