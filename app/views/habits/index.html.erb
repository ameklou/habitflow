<% content_for :title, "Habits" %>

<section class="py-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-slate-950">Habits</h1>
      <p class="mt-2 text-sm text-slate-600">Manage the habits you want to track each day.</p>
    </div>

    <%= link_to "New habit", new_habit_path, class: "inline-flex items-center justify-center rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
  </div>

  <% if @habits.any? %>
    <%= render "completion_summary", habits: @habits %>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <%= render @habits %>
    </div>
  <% else %>
    <div class="mt-8 rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center">
      <h2 class="text-lg font-semibold text-slate-950">No habits yet</h2>
      <p class="mt-2 text-sm text-slate-600">Create your first habit to start tracking progress.</p>
      <%= link_to "Create habit", new_habit_path, class: "mt-5 inline-flex rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    </div>
  <% end %>
</section>
