<% today = local_assigns.fetch(:date, Time.zone.today) %>
<% active_habits = habits.reject(&:archived?) %>
<% completed_count = active_habits.count { |habit| habit.completed_on?(today) } %>
<% remaining_count = active_habits.size - completed_count %>

<div id="habits_completion_summary" class="mt-8 grid gap-4 sm:grid-cols-3">
  <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
    <p class="text-sm text-slate-500">Today</p>
    <p class="mt-1 text-2xl font-bold text-slate-950"><%= active_habits.size %></p>
  </div>
  <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 shadow-sm">
    <p class="text-sm text-emerald-700">Completed</p>
    <p class="mt-1 text-2xl font-bold text-emerald-900"><%= completed_count %></p>
  </div>
  <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 shadow-sm">
    <p class="text-sm text-amber-700">Remaining</p>
    <p class="mt-1 text-2xl font-bold text-amber-900"><%= remaining_count %></p>
  </div>
</div>
