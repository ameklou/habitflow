<% content_for :title, "New habit" %>

<section class="mx-auto max-w-2xl py-10">
  <div>
    <h1 class="text-3xl font-bold tracking-tight text-slate-950">New habit</h1>
    <p class="mt-2 text-sm text-slate-600">Define the habit you want to make visible in your daily routine.</p>
  </div>

  <div class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <%= render "form", habit: @habit %>
  </div>
</section>
