<% content_for :title, @habit.name %>

<section class="mx-auto max-w-3xl py-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-sm font-medium text-slate-500">Habit</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-950"><%= @habit.name %></h1>
      <p class="mt-3 text-slate-700"><%= @habit.description.presence || "No description added." %></p>
    </div>

    <% if @habit.archived? %>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">Archived</span>
    <% elsif @habit.active? %>
      <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800">Active</span>
    <% end %>
  </div>

  <dl class="mt-8 grid gap-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm sm:grid-cols-2">
    <div>
      <dt class="text-sm text-slate-500">Frequency</dt>
      <dd class="mt-1 font-semibold capitalize text-slate-950"><%= @habit.frequency.humanize %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">Category</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @habit.category&.name || "Uncategorized" %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">Goal count</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= pluralize(@habit.goal_count, "time") %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">Reminder time</dt>
      <dd class="mt-1 font-semibold text-slate-950"><%= @habit.reminder_time&.strftime("%H:%M") || "None" %></dd>
    </div>
    <div>
      <dt class="text-sm text-slate-500">Color</dt>
      <dd class="mt-1 flex items-center gap-2 font-semibold text-slate-950">
        <% if @habit.color.present? %>
          <span class="h-4 w-4 rounded-full border border-slate-200" style="background-color: <%= @habit.color %>"></span>
          <%= @habit.color %>
        <% else %>
          None
        <% end %>
      </dd>
    </div>
  </dl>

  <%= render "completion_panel", habit: @habit %>

  <div class="mt-8 flex flex-wrap gap-3">
    <%= link_to "Back to habits", habits_path, class: "rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    <%= link_to "Edit", edit_habit_path(@habit), class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    <% unless @habit.archived? %>
      <%= button_to "Archive", archive_habit_path(@habit), method: :patch, class: "rounded-md border border-amber-300 px-4 py-2 text-sm font-semibold text-amber-800 hover:bg-amber-50" %>
    <% end %>
    <%= button_to "Delete", habit_path(@habit), method: :delete, data: { turbo_confirm: "Delete this habit permanently?" }, class: "rounded-md border border-red-300 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
  </div>
</section>
