<%= form_with(model: habit, class: "space-y-6") do |form| %>
  <% if habit.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <h2 class="font-semibold"><%= pluralize(habit.errors.count, "error") %> prevented this habit from being saved.</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <% habit.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-slate-800" %>
    <%= form.text_field :name, autofocus: true, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-slate-800" %>
    <%= form.text_area :description, rows: 4, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
  </div>

  <div>
    <%= form.label :category_id, "Category", class: "block text-sm font-medium text-slate-800" %>
    <%= form.collection_select :category_id, @categories, :id, :name, { include_blank: "Uncategorized" }, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <%= form.label :frequency, class: "block text-sm font-medium text-slate-800" %>
      <%= form.select :frequency, Habit.frequencies.keys.map { |frequency| [ frequency.humanize, frequency ] }, {}, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div>
      <%= form.label :goal_count, class: "block text-sm font-medium text-slate-800" %>
      <%= form.number_field :goal_count, min: 1, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>
  </div>

  <fieldset>
    <legend class="text-sm font-medium text-slate-800">Custom days</legend>
    <%= hidden_field_tag "habit[days_of_week][]", "" %>
    <div class="mt-3 grid gap-2 sm:grid-cols-2">
      <% Habit::DAYS_OF_WEEK.each do |label, value| %>
        <label class="flex items-center gap-2 rounded-md border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700">
          <%= check_box_tag "habit[days_of_week][]", value, habit.days_of_week.include?(value), id: "habit_days_of_week_#{value}", class: "h-4 w-4 rounded border-slate-300 text-emerald-700 focus:ring-emerald-600" %>
          <%= label %>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div class="grid gap-5 sm:grid-cols-3">
    <div>
      <%= form.label :color, class: "block text-sm font-medium text-slate-800" %>
      <%= form.color_field :color, class: "mt-2 h-10 w-full rounded-md border border-slate-300 px-2 py-1 shadow-sm" %>
    </div>

    <div>
      <%= form.label :icon, class: "block text-sm font-medium text-slate-800" %>
      <%= form.text_field :icon, placeholder: "check", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>

    <div>
      <%= form.label :reminder_time, class: "block text-sm font-medium text-slate-800" %>
      <%= form.time_field :reminder_time, class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= form.check_box :active, class: "h-4 w-4 rounded border-slate-300 text-emerald-700 focus:ring-emerald-600" %>
    <%= form.label :active, class: "text-sm text-slate-700" %>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= form.submit class: "rounded-md bg-emerald-700 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
    <%= link_to "Cancel", habits_path, class: "rounded-md border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>
