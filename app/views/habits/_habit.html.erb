<% today = local_assigns.fetch(:date, Time.zone.today) %>
<% completion = habit.completion_on(today) %>

<article id="<%= dom_id(habit, :card) %>" class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm <%= "opacity-70" if habit.archived? %>">
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-2">
        <% if habit.color.present? %>
          <span class="h-3 w-3 rounded-full" style="background-color: <%= habit.color %>"></span>
        <% end %>
        <h2 class="font-semibold text-slate-950"><%= link_to habit.name, habit, class: "hover:text-emerald-700" %></h2>
      </div>
      <p class="mt-2 text-sm text-slate-600"><%= habit.description.presence || "No description added." %></p>
      <% if habit.category.present? %>
        <p class="mt-2 text-xs font-medium text-slate-500">Category: <%= habit.category.name %></p>
      <% end %>
      <% if completion&.note.present? %>
        <p class="mt-2 rounded-md bg-emerald-50 px-3 py-2 text-sm text-emerald-800">Note: <%= completion.note %></p>
      <% end %>
    </div>

    <% if habit.archived? %>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">Archived</span>
    <% elsif completion.present? %>
      <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-800">Completed</span>
    <% elsif habit.active? %>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">Active</span>
    <% end %>
  </div>

  <dl class="mt-4 grid grid-cols-2 gap-3 text-sm">
    <div>
      <dt class="text-slate-500">Frequency</dt>
      <dd class="mt-1 font-medium capitalize text-slate-900"><%= habit.frequency.humanize %></dd>
    </div>
    <div>
      <dt class="text-slate-500">Goal</dt>
      <dd class="mt-1 font-medium text-slate-900"><%= pluralize(habit.goal_count, "time") %></dd>
    </div>
  </dl>

  <% unless habit.archived? %>
    <div class="mt-5">
      <% if completion.present? %>
        <%= button_to "Undo completion", habit_completion_path(habit), method: :delete, class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      <% else %>
        <%= form_with(url: habit_completion_path(habit), scope: :habit_completion, class: "space-y-3") do |form| %>
          <%= form.label :note, "Completion note", class: "block text-sm font-medium text-slate-700" %>
          <div class="flex flex-col gap-2 sm:flex-row">
            <%= form.text_field :note, placeholder: "Optional note", class: "min-w-0 flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20" %>
            <%= form.submit "Complete today", class: "rounded-md bg-emerald-700 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-800" %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="mt-5 flex flex-wrap gap-2">
    <%= link_to "Edit", edit_habit_path(habit), class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    <% unless habit.archived? %>
      <%= button_to "Archive", archive_habit_path(habit), method: :patch, class: "rounded-md border border-amber-300 px-3 py-2 text-sm font-semibold text-amber-800 hover:bg-amber-50" %>
    <% end %>
    <%= button_to "Delete", habit_path(habit), method: :delete, data: { turbo_confirm: "Delete this habit permanently?" }, class: "rounded-md border border-red-300 px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
  </div>
</article>
